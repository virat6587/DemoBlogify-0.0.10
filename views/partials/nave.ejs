<!-- Navigation Bar with Dark Mode & Notifications -->
<nav class="navbar navbar-expand-lg sticky-top" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); box-shadow: 0 2px 15px rgba(0,0,0,0.1);">
    <div class="container-fluid">
        <!-- Brand -->
        <a class="navbar-brand fw-bold fs-3 text-primary" href="/">
            <i class="fas fa-feather"></i> Blogify
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <!-- Left side links -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link fw-medium" href="/">
                        <i class="fas fa-home"></i> Home
                    </a>
                </li>
                <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/blogs/add-new">
                            <i class="fas fa-plus"></i> Write
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/user/profile">
                            <i class="fas fa-book"></i> My Blogs
                        </a>
                    </li>
                <% } %>
            </ul>

            <!-- Right side links -->
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <!-- Search -->
                <li class="nav-item">
                    <form class="d-flex" method="GET" action="/">
                        <input class="form-control form-control-sm" type="search" name="search" placeholder="Search blogs...">
                    </form>
                </li>

                <% if (locals.user) { %>
                    <!-- Notifications Bell -->
                    <li class="nav-item">
                        <a href="/notifications" class="btn btn-link position-relative" id="notificationBell" title="Notifications" style="text-decoration: none;">
                            <i class="fas fa-bell fa-lg" style="color: #6366f1;"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none;">
                                <span id="notificationCount">0</span>
                            </span>
                        </a>
                    </li>

                    <!-- Dark Mode Toggle -->
                    <li class="nav-item">
                        <button class="btn btn-link" id="themeToggle" title="Toggle Dark Mode" style="text-decoration: none;">
                            <i class="fas fa-moon fa-lg" style="color: #6366f1;"></i>
                        </button>
                    </li>

                    <!-- User Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img 
                                src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                                alt="<%= locals.user.fullName %>" 
                                width="36" 
                                height="36" 
                                class="rounded-circle border border-2 border-light shadow-sm" 
                                style="object-fit: cover;"
                                onerror="this.src='/imgs/default.png';">
                            <span class="fw-medium text-dark d-none d-md-inline">
                                <%= locals.user.fullName.split(" ")[0] %>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow" style="border-radius: 12px;">
                            <li class="dropdown-header">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                                         width="32" height="32" class="rounded-circle" 
                                         onerror="this.src='/imgs/default.png';">
                                    <div>
                                        <p class="mb-0 fw-bold"><%= locals.user.fullName %></p>
                                        <small class="text-muted"><%= locals.user.email %></small>
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            
                            <li>
                                <a class="dropdown-item" href="/user/profile">
                                    <i class="fas fa-user-circle"></i> My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/user/profile?tab=followers">
                                    <i class="fas fa-users"></i> Followers
                                    <span class="badge bg-primary ms-2"><%= locals.user.followers ? locals.user.followers.length : 0 %></span>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/user/profile?tab=following">
                                    <i class="fas fa-heart"></i> Following
                                    <span class="badge bg-primary ms-2"><%= locals.user.following ? locals.user.following.length : 0 %></span>
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            
                            <li>
                                <a class="dropdown-item" href="/notifications">
                                    <i class="fas fa-bell"></i> Notifications
                                    <span class="badge bg-danger ms-1" id="navNotifCount" style="display:none;">0</span>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" id="analyticsBtn">
                                    <i class="fas fa-chart-line"></i> My Analytics
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/settings">
                                    <i class="fas fa-cog"></i> Settings
                                </a>
                            </li>

                            <% if (locals.user.role === "ADMIN") { %>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-info" href="/admin/users">
                                        <i class="fas fa-shield-alt"></i> Admin Panel
                                    </a>
                                </li>
                            <% } %>

                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger fw-medium" href="/user/logout">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                <% } else { %>
                    <!-- Auth Buttons (Not Logged In) -->
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/user/signup">
                            <i class="fas fa-user-plus"></i> Sign Up
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary rounded-pill px-4 py-2 fw-medium" href="/user/signin">
                            Sign In
                        </a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<!-- Global Error Alert -->
<% if (locals.error) { %>
    <div class="container-fluid mt-5 pt-5">
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle"></i> <%= locals.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<% } %>

<script>
    // ==================== DARK MODE TOGGLE (DB + LocalStorage Sync) ====================
    const themeToggle = document.getElementById('themeToggle');
    const htmlElement = document.documentElement;
    
    const dbTheme = '<%= locals.user ? locals.user.theme : "" %>';
    const savedTheme = dbTheme || localStorage.getItem('theme') || 'light';

    function applyTheme(theme) {
        if (theme === 'dark') {
            document.body.classList.add('dark-mode');
            themeToggle.innerHTML = '<i class="fas fa-sun fa-lg" style="color: #fbbf24;"></i>';
        } else {
            document.body.classList.remove('dark-mode');
            themeToggle.innerHTML = '<i class="fas fa-moon fa-lg" style="color: #6366f1;"></i>';
        }
    }

    applyTheme(savedTheme);

    themeToggle.addEventListener('click', async () => {
        const isDarkMode = !document.body.classList.contains('dark-mode');
        const newTheme = isDarkMode ? 'dark' : 'light';
        
        document.body.classList.toggle('dark-mode');
        applyTheme(newTheme);
        localStorage.setItem('theme', newTheme);

        <% if (locals.user) { %>
            try {
                await fetch('/user/profile/update', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ theme: newTheme })
                });
            } catch (err) {
                console.error('Failed to sync theme to DB:', err);
            }
        <% } %>
    });

    // ==================== NOTIFICATION COUNT ====================
    <% if (locals.user) { %>
        async function loadNotifCount() {
            try {
                const res = await fetch('/notifications/unread/count');
                const data = await res.json();
                if (data.success && data.unreadCount > 0) {
                    const badge = document.getElementById('notificationBadge');
                    const navBadge = document.getElementById('navNotifCount');
                    document.getElementById('notificationCount').textContent = data.unreadCount;
                    badge.style.display = 'inline';
                    if (navBadge) {
                        navBadge.textContent = data.unreadCount;
                        navBadge.style.display = 'inline';
                    }
                }
            } catch (err) {
                console.error('Error loading notification count:', err);
            }
        }
        loadNotifCount();
    <% } %>
</script>
