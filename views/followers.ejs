<% locals.activeNav = 'profile'; %>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="d-flex align-items-center mb-4">
                    <a href="/user/profile/<%= typeof userId !== 'undefined' ? userId : '' %>" class="btn btn-light btn-sm me-3"><i class="bi bi-arrow-left"></i> Back</a>
                    <h2 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Followers</h2>
                </div>

                <% if (!followers || followers.length === 0) { %>
                <div class="empty-state">
                    <i class="bi bi-people"></i>
                    <h4>No followers yet</h4>
                    <p class="text-secondary">When someone follows you, they'll appear here.</p>
                </div>
                <% } else { %>
                <div class="list-group list-group-flush">
                    <% followers.forEach(follower => { %>
                    <div class="list-group-item d-flex align-items-center gap-3 p-3">
                        <img src="<%= follower.profileImageURL || '/imgs/default.png' %>" alt="<%= follower.fullName %>" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;" onerror="this.src='/imgs/default.png';">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-0"><a href="/user/profile/<%= follower._id %>" class="text-dark text-decoration-none"><%= follower.fullName %></a></h6>
                            <small class="text-muted"><%= follower.bio ? truncate(follower.bio, 60) : 'No bio' %></small>
                        </div>
                        <% if (locals.user && user._id.toString() !== follower._id.toString()) { %>
                        <button class="follow-btn btn btn-sm <%= user.following && user.following.includes(follower._id.toString()) ? 'btn-primary' : 'btn-outline-primary' %>" data-user-id="<%= follower._id %>">
                            <i class="bi <%= user.following && user.following.includes(follower._id.toString()) ? 'bi-person-check-fill' : 'bi-person-plus' %>"></i>
                            <%= user.following && user.following.includes(follower._id.toString()) ? 'Following' : 'Follow' %>
                        </button>
                        <% } %>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</section>
