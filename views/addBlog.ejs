<% locals.activeNav = 'write'; %>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex align-items-center mb-4">
                    <a href="/" class="btn btn-light btn-sm me-3"><i class="bi bi-arrow-left"></i> Back</a>
                    <h2 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Write New Blog</h2>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">
                        <form action="/blogs" method="POST" enctype="multipart/form-data" data-validate>
                            <div class="mb-4">
                                <label class="form-label fw-medium">Blog Title <span class="text-danger">*</span></label>
                                <input type="text" name="title" class="form-control form-control-lg" placeholder="Enter an engaging title..." required maxlength="200">
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium">Excerpt</label>
                                <textarea name="excerpt" class="form-control" rows="2" placeholder="Brief summary of your blog..." maxlength="300"></textarea>
                                <small class="text-muted">Short description shown in blog cards</small>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="form-label fw-medium">Cover Image</label>
                                    <input type="file" name="coverImage" class="form-control" accept="image/*">
                                    <small class="text-muted">Recommended: 1200x630px</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">Or Image URL</label>
                                    <input type="url" name="coverImageURL" class="form-control" placeholder="https://...">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium">Tags <span class="text-muted">(comma separated)</span></label>
                                <input type="text" name="tags" class="form-control" placeholder="technology, programming, tutorial">
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium">Category</label>
                                <select name="category" class="form-select">
                                    <option value="">Select category...</option>
                                    <option value="technology">Technology</option>
                                    <option value="programming">Programming</option>
                                    <option value="design">Design</option>
                                    <option value="business">Business</option>
                                    <option value="lifestyle">Lifestyle</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium">Content <span class="text-danger">*</span></label>
                                <textarea name="body" id="blogBody" class="form-control" rows="15" placeholder="Write your story here... Markdown supported" required></textarea>
                                <small class="text-muted">Supports Markdown formatting</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-medium">Status</label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="status" value="published" id="statusPublished" checked>
                                        <label class="form-check-label" for="statusPublished"><i class="bi bi-globe me-1"></i>Publish Now</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="status" value="draft" id="statusDraft">
                                        <label class="form-check-label" for="statusDraft"><i class="bi bi-save me-1"></i>Save as Draft</label>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-lg me-2"></i>Publish Blog</button>
                                <a href="/" class="btn btn-outline-secondary btn-lg">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
