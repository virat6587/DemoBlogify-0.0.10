<nav class="navbar navbar-expand-lg" id="mainNavbar">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="bi bi-journal-text"></i>
            <span>Blogify</span>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'active' : '' %>" href="/">
                        <i class="bi bi-house"></i>
                        <span>Home</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'blogs' ? 'active' : '' %>" href="/blogs">
                        <i class="bi bi-grid"></i>
                        <span>Blogs</span>
                    </a>
                </li>
                <% if (locals.user) { %>
                <li class="nav-item">
                    <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'write' ? 'active' : '' %>" href="/blogs/add-new">
                        <i class="bi bi-pencil-square"></i>
                        <span>Write</span>
                    </a>
                </li>
                <% } %>
            </ul>

            <div class="d-flex align-items-center gap-2">
                <!-- Search -->
                <form class="search-box d-none d-md-block" action="/" method="GET">
                    <i class="bi bi-search"></i>
                    <input type="search" name="search" class="form-control form-control-sm" 
                           placeholder="Search blogs..." 
                           value="<%= typeof search !== 'undefined' ? search : '' %>">
                </form>

                <!-- Theme Toggle -->
                <button class="theme-toggle" id="themeToggle" title="Toggle theme" aria-label="Toggle dark mode">
                    <i class="bi bi-moon-stars" id="themeIcon"></i>
                </button>

                <% if (locals.user) { %>
                <!-- Notifications -->
                <a href="/notifications" class="btn btn-sm btn-light position-relative" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="notifBadge">
                        0
                    </span>
                </a>

                <!-- User Dropdown -->
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle" 
                       data-bs-toggle="dropdown" aria-expanded="false" id="userDropdown">
                        <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                             alt="<%= locals.user.fullName %>" 
                             class="avatar"
                             onerror="this.src='/imgs/default.png';">
                        <span class="d-none d-lg-block fw-medium text-dark"><%= locals.user.fullName %></span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" aria-labelledby="userDropdown">
                        <li>
                            <a class="dropdown-item" href="/user/profile">
                                <i class="bi bi-person me-2"></i>Profile
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/analytics">
                                <i class="bi bi-graph-up me-2"></i>Analytics
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/settings">
                                <i class="bi bi-gear me-2"></i>Settings
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="/user/logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </a>
                        </li>
                    </ul>
                </div>
                <% } else { %>
                <!-- Guest Buttons -->
                <a href="/user/signin" class="btn btn-outline-primary btn-sm">Sign In</a>
                <a href="/user/signup" class="btn btn-primary btn-sm">Get Started</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<!-- Reading Progress Bar -->
<div class="reading-progress" id="readingProgress" style="width: 0%"></div>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>
