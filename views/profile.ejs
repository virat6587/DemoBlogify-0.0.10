<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= user.fullName %> - Profile | Blogify</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <style>
        body { background-color: #0b0c10; color: #f1f1f1; }
        .profile-header {
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            padding: 60px 0;
            border-radius: 0 0 30px 30px;
        }
        .profile-img {
            width: 140px;
            height: 140px;
            object-fit: cover;
            border: 5px solid white;
        }
        .blog-card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s;
        }
        .blog-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.6);
        }
        .blog-img {
            height: 200px;
            object-fit: cover;
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <!-- Profile Header -->
    <div class="profile-header text-center">
        <div class="container">
            <img src="<%= user.profileImageURL || '/imgs/default.png' %>" 
                 alt="<%= user.fullName %>" 
                 class="rounded-circle profile-img mb-3"
                 onerror="this.src='/imgs/default.png';">
            <h2 class="fw-bold"><%= user.fullName %></h2>
            <p class="lead opacity-75"><%= user.email %></p>
            <span class="badge bg-light text-dark fs-6 px-3 py-2"><%= user.role %></span>
        </div>
    </div>

    <div class="container mt-5">
        <h3 class="mb-4">📝 My Blogs (<%= blogs.length %>)</h3>

        <% if (blogs.length === 0) { %>
            <div class="text-center py-5">
                <h5 class="text-muted">You haven't posted any blogs yet.</h5>
                <a href="/blogs/add-new" class="btn btn-primary mt-3">Write Your First Blog</a>
            </div>
        <% } else { %>
            <div class="row">
                <% blogs.forEach(blog => { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card blog-card h-100">
                            <div class="position-relative">
                                <% if (blog.coverImageURL) { %>
                                    <img src="<%= blog.coverImageURL %>" 
                                         class="blog-img w-100" 
                                         alt="<%= blog.title %>"
                                         onerror="this.src='/images/default-blog.png';">
                                <% } else { %>
                                    <div class="bg-secondary text-center py-5 blog-img d-flex align-items-center justify-content-center">
                                        <i class="fas fa-image fa-3x text-muted"></i>
                                    </div>
                                <% } %>

                                <div class="dropdown position-absolute top-0 end-0 m-3">
                                    <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="/blogs/<%= blog._id %>"><i class="fas fa-eye"></i> View</a></li>
                                        <li><a class="dropdown-item" href="/blogs/edit/<%= blog._id %>"><i class="fas fa-edit"></i> Edit</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" 
                                               href="#" 
                                               onclick="deleteBlog('<%= blog._id %>')">
                                               <i class="fas fa-trash"></i> Delete
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="card-body">
                                <h5 class="card-title"><%= blog.title %></h5>
                                <p class="card-text text-light opacity-75">
                                    <%= blog.body ? blog.body.substring(0, 120) : '' %>...
                                </p>
                                <small class="text-muted">
                                    <%= new Date(blog.createdAt).toLocaleDateString('en-IN') %>
                                </small>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        function deleteBlog(id) {
            if (confirm("Are you sure you want to delete this blog?")) {
                fetch(`/blogs/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert("Blog deleted successfully");
                            location.reload();
                        } else {
                            alert(data.message || "Failed to delete");
                        }
                    })
                    .catch(() => alert("Error deleting blog"));
            }
        }
    </script>
</body>
</html>
