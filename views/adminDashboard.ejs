<% locals.activeNav = 'admin'; %>

<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2 text-primary"></i>Admin Dashboard</h2>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-people text-primary fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-1"><%= typeof totalUsers !== 'undefined' ? totalUsers : 0 %></h3>
                    <p class="text-secondary mb-0">Total Users</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-journal-text text-success fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-1"><%= typeof totalBlogs !== 'undefined' ? totalBlogs : 0 %></h3>
                    <p class="text-secondary mb-0">Total Blogs</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-chat-left-text text-info fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-1"><%= typeof totalComments !== 'undefined' ? totalComments : 0 %></h3>
                    <p class="text-secondary mb-0">Comments</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4">
                    <i class="bi bi-eye text-warning fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-1"><%= typeof totalViews !== 'undefined' ? totalViews : 0 %></h3>
                    <p class="text-secondary mb-0">Total Views</p>
                </div>
            </div>
        </div>

        <h4 class="fw-bold mb-3">Recent Blogs</h4>
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Status</th>
                            <th>Views</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentBlogs !== 'undefined' && recentBlogs.length > 0) { %>
                        <% recentBlogs.forEach(blog => { %>
                        <tr>
                            <td><a href="/blogs/<%= blog._id %>" class="text-decoration-none fw-medium"><%= truncate(blog.title, 40) %></a></td>
                            <td><%= blog.createdBy ? blog.createdBy.fullName : 'Unknown' %></td>
                            <td><span class="badge bg-<%= blog.status === 'published' ? 'success' : 'warning' %>"><%= blog.status %></span></td>
                            <td><%= blog.viewCount || 0 %></td>
                            <td><%= formatDate(blog.createdAt) %></td>
                            <td>
                                <a href="/admin/blogs/<%= blog._id %>/feature" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-star"></i></a>
                                <a href="/admin/blogs/<%= blog._id %>/delete" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this blog?')"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                        <% }) %>
                        <% } else { %>
                        <tr><td colspan="6" class="text-center text-muted py-4">No blogs found</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
