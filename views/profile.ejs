<% locals.activeNav = 'profile'; %>

<section class="py-5">
    <div class="container">
        <div class="card border-0 shadow-sm mb-4 overflow-hidden">
            <div style="height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
            <div class="card-body p-4">
                <div class="d-flex flex-wrap align-items-end" style="margin-top: -60px;">
                    <img src="<%= profileUser.profileImageURL || '/imgs/default.png' %>" alt="<%= profileUser.fullName %>" class="rounded-circle border-4 border-white shadow" style="width: 120px; height: 120px; object-fit: cover;" onerror="this.src='/imgs/default.png';">
                    <div class="ms-4 flex-grow-1 mb-2">
                        <h2 class="fw-bold mb-1"><%= profileUser.fullName %></h2>
                        <p class="text-secondary mb-2"><%= profileUser.bio || 'No bio yet.' %></p>
                        <div class="d-flex gap-3 text-muted">
                            <span><strong class="text-dark"><%= typeof blogCount !== 'undefined' ? blogCount : 0 %></strong> posts</span>
                            <span><strong class="text-dark"><%= typeof followerCount !== 'undefined' ? followerCount : 0 %></strong> followers</span>
                            <span><strong class="text-dark"><%= typeof followingCount !== 'undefined' ? followingCount : 0 %></strong> following</span>
                        </div>
                    </div>
                    <% if (locals.user && user._id.toString() !== profileUser._id.toString()) { %>
                    <button class="follow-btn btn <%= isFollowing ? 'btn-primary' : 'btn-outline-primary' %> mb-2" data-user-id="<%= profileUser._id %>">
                        <i class="bi <%= isFollowing ? 'bi-person-check-fill' : 'bi-person-plus' %>"></i>
                        <%= isFollowing ? 'Following' : 'Follow' %>
                    </button>
                    <% } else if (locals.user && user._id.toString() === profileUser._id.toString()) { %>
                    <a href="/user/profile/edit" class="btn btn-outline-primary mb-2"><i class="bi bi-pencil me-1"></i>Edit Profile</a>
                    <% } %>
                </div>
            </div>
        </div>

        <h3 class="fw-bold mb-4"><i class="bi bi-journal-text me-2 text-primary"></i>Blogs by <%= profileUser.fullName %></h3>

        <% if (!blogs || blogs.length === 0) { %>
        <div class="empty-state">
            <i class="bi bi-journal-x"></i>
            <h4>No blogs yet</h4>
            <p class="text-secondary">This user hasn't published any blogs.</p>
        </div>
        <% } else { %>
        <div class="row g-4">
            <% blogs.forEach(blog => { %>
            <div class="col-md-6 col-lg-4">
                <article class="card h-100">
                    <% if (blog.coverImageURL) { %>
                    <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>" loading="lazy" style="height: 180px; object-fit: cover;" onerror="this.style.display='none';">
                    <% } %>
                    <div class="card-body">
                        <h5 class="card-title"><a href="/blogs/<%= blog._id %>" class="text-dark text-decoration-none stretched-link"><%= truncate(blog.title, 50) %></a></h5>
                        <p class="card-text text-secondary"><%= truncate(blog.excerpt || blog.body, 80) %></p>
                        <small class="text-muted"><%= formatDate(blog.createdAt) %> &bull; <%= blog.readingTime || 5 %> min</small>
                    </div>
                </article>
            </div>
            <% }) %>
        </div>
        <% } %>
    </div>
</section>
