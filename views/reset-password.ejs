<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Reset Password - Blogify</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            height: 100%;
        }

        body {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #764ba2 100%);
            min-height: 100dvh;
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 0.75rem;
        }

        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
            padding: 0.5rem 0;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
            animation: slideIn 0.4s ease-out;
        }

        .auth-card-body {
            padding: 1.75rem 1.5rem;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 1.25rem;
        }

        .auth-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.3rem;
            letter-spacing: -0.5px;
        }

        .auth-header p {
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 0.85rem;
        }

        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 0.35rem;
            display: block;
            font-size: 0.85rem;
        }

        .form-control {
            width: 100%;
            border-radius: 10px;
            padding: 0.7rem 0.85rem;
            border: 2px solid #e2e8f0;
            font-size: 16px;
            font-weight: 500;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
            outline: none;
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .input-group {
            display: flex;
            align-items: stretch;
        }

        .input-group .form-control {
            border-radius: 10px 0 0 10px;
            margin: 0;
        }

        .input-group .btn {
            border-radius: 0 10px 10px 0;
            border: 2px solid #e2e8f0;
            border-left: none;
            background: white;
            color: #64748b;
            font-size: 1.1rem;
            padding: 0.7rem 0.85rem;
            min-width: 44px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .input-group .btn:hover {
            background: #f8fafc;
            color: #334155;
        }

        .btn-reset {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            border: none;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .btn-reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(99, 102, 241, 0.3);
        }

        .btn-reset:active {
            transform: translateY(0);
        }

        .btn-reset:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .signin-link {
            text-align: center;
            margin-top: 1rem;
            color: #64748b;
            font-size: 0.85rem;
        }

        .signin-link a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s ease;
        }

        .signin-link a:hover {
            color: #4f46e5;
        }

        .alert {
            border-radius: 10px;
            padding: 0.85rem;
            margin-bottom: 1rem;
            border: none;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .alert-danger {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .alert-success {
            background-color: #dcfce7;
            color: #166534;
        }

        /* Animations */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Loading State */
        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            vertical-align: text-bottom;
            border: 2px solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border 0.75s linear infinite;
        }

        @keyframes spinner-border {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @media (max-width: 576px) {
            body {
                padding: 0.5rem;
                justify-content: flex-start;
                padding-top: 0.75rem;
                padding-bottom: 0.75rem;
            }

            .auth-container {
                align-items: flex-start;
                padding: 0;
            }

            .auth-card {
                max-width: 100%;
                border-radius: 14px;
            }

            .auth-card-body {
                padding: 1.5rem 1.25rem;
            }

            .auth-header h2 {
                font-size: 1.35rem;
            }

            .auth-header p {
                font-size: 0.8rem;
            }

            .form-control {
                padding: 0.65rem 0.8rem;
                font-size: 16px;
            }

            .form-label {
                font-size: 0.82rem;
            }

            .btn-reset {
                padding: 0.75rem 1.5rem;
            }
        }

        @media (max-width: 360px) {
            .auth-card-body {
                padding: 1.25rem 1rem;
            }

            .auth-header h2 {
                font-size: 1.2rem;
            }

            .auth-header {
                margin-bottom: 1rem;
            }
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-body">
                <div class="auth-header">
                    <h2>Reset Password</h2>
                    <p>Create a new password for your account</p>
                </div>

                <% if (error) { %>
                    <div class="alert alert-danger">
                        <%= error %>
                    </div>
                <% } %>

                <form id="resetPasswordForm">
                    <input type="hidden" name="token" id="token" value="<%= token %>">

                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <div class="input-group">
                            <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="••••••••" required minlength="6">
                            <button type="button" class="btn" id="toggleNewPassword" title="Toggle password visibility">
                                👁️
                            </button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="••••••••" required minlength="6">
                            <button type="button" class="btn" id="toggleConfirmPassword" title="Toggle password visibility">
                                👁️
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-reset" id="submitBtn">
                        Reset Password
                    </button>
                </form>

                <p class="signin-link">
                    Remember your password? 
                    <a href="/user/signin">Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        // Password Toggle for New Password
        document.getElementById('toggleNewPassword').addEventListener('click', function () {
            const pw = document.getElementById('newPassword');
            if (pw.type === 'password') {
                pw.type = 'text';
                this.textContent = '🙈';
            } else {
                pw.type = 'password';
                this.textContent = '👁️';
            }
        });

        // Password Toggle for Confirm Password
        document.getElementById('toggleConfirmPassword').addEventListener('click', function () {
            const pw = document.getElementById('confirmPassword');
            if (pw.type === 'password') {
                pw.type = 'text';
                this.textContent = '🙈';
            } else {
                pw.type = 'password';
                this.textContent = '👁️';
            }
        });

        // Reset Password Form Submit
        document.getElementById('resetPasswordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const token = document.getElementById('token').value;

            // Client-side validation
            if (newPassword !== confirmPassword) {
                alert("Passwords do not match!");
                return;
            }

            if (newPassword.length < 6) {
                alert("Password must be at least 6 characters!");
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border me-2"></span>Resetting...`;

            try {
                const res = await fetch('/user/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, newPassword, confirmPassword })
                });

                const result = await res.json();

                if (result.success) {
                    alert("✅ Password reset successfully!");
                    window.location.href = result.redirect || "/user/signin";
                } else {
                    alert(result.message || "Failed to reset password");
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Reset Password";
                }
            } catch (err) {
                alert("Something went wrong. Please try again.");
                submitBtn.disabled = false;
                submitBtn.textContent = "Reset Password";
            }
        });
    </script>
</body>
</html>
