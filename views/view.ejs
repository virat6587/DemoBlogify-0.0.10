                    <button onclick="postPopupComment()" id="popupPostBtn"><i class="fas fa-paper-plane"></i></button>
                </div>
            <% } else { %>
                <div class="text-center py-2"><a href="/user/signin" class="btn btn-primary btn-sm">Sign in to comment</a></div>
            <% } %>
        </div>
    </div>

    <button class="comment-fab" id="commentFab" onclick="openCommentPopup()" title="Open comments">
        <i class="fas fa-comment-alt"></i>
        <span class="badge-count" id="fabBadgeCount" style="display:none;">0</span>
    </button>

    <%- include("./partials/scripts") %>

    <script>
        const blogId = '<%= blog._id %>';
        const currentUserId = '<%= locals.user ? locals.user._id : "" %>';
        const currentUserName = '<%= locals.user ? locals.user.fullName : "" %>';
        const currentUserImage = '<%= locals.user ? locals.user.profileImageURL : "/imgs/default.png" %>';
        const blogAuthorId = '<%= blog.createdBy._id %>';
        let isFollowingAuthor = false;
        let popupReplyToId = null;
        let allComments = [];

        function timeAgo(date) {
            const s = Math.floor((new Date() - new Date(date)) / 1000);
            if (s < 60) return 'Just now';
            const m = Math.floor(s / 60);
            if (m < 60) return m + 'm ago';
            const h = Math.floor(m / 60);
            if (h < 24) return h + 'h ago';
            const d = Math.floor(h / 24);
            if (d < 30) return d + 'd ago';
            const mo = Math.floor(d / 30);
            if (mo < 12) return mo + 'mo ago';
            return Math.floor(mo / 12) + 'y ago';
        }

        function esc(text) {
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        function renderComment(c, depth = 0) {
            if (!c || c.isDeleted) return '';
            const isAuthor = currentUserId && c.author && c.author._id.toString() === currentUserId;
            const isBlogOwner = currentUserId === blogAuthorId;
            const canDelete = isAuthor || isBlogOwner;
            const hasLiked = c.likes && c.likes.some(id => id.toString() === currentUserId);
            const fromAuthor = c.author && c.author._id.toString() === blogAuthorId;
            const img = c.author?.profileImageURL || '/imgs/default.png';
            const name = c.author?.fullName || 'Unknown';

            let repliesHtml = '';
            if (c.replies && c.replies.length > 0) {
                const valid = c.replies.filter(r => r && !r.isDeleted);
                if (valid.length > 0) {
                    repliesHtml = `<div class="replies">${valid.map(r => renderComment(r, depth + 1)).join('')}</div>`;
                }
            }

            return `
                <div class="comment-box" id="comment-${c._id}" style="${depth > 0 ? 'background:#f8fafc;' : ''}">
                    <div class="comment-header">
                        <img src="${img}" onerror="this.src='/imgs/default.png';">
                        <div>
                            <span class="name">${esc(name)} ${fromAuthor ? '<span class="author-badge">Author</span>' : ''}</span>
                            <div class="time">${timeAgo(c.createdAt)} ${c.isEdited ? '• edited' : ''}</div>
                        </div>
                        ${canDelete ? `
                            <div class="cmenu ms-auto">
                                <button class="cmenu-btn" onclick="toggleMenu('${c._id}',event)"><i class="fas fa-ellipsis-v"></i></button>
                                <div class="cmenu-drop" id="menu-${c._id}">
                                    ${isAuthor ? `<div class="cmenu-item" onclick="startEdit('${c._id}')"><i class="fas fa-edit"></i> Edit</div>` : ''}
                                    <div class="cmenu-item del" onclick="deleteComment('${c._id}')"><i class="fas fa-trash"></i> Delete</div>
                                </div>
                            </div>
                        ` : ''}
                    </div>
                    <div class="comment-text" id="text-${c._id}">${esc(c.content)}</div>
                    <div class="edit-box" id="edit-${c._id}">
                        <textarea id="edit-text-${c._id}">${esc(c.content)}</textarea>
                        <div class="edit-btns">
                            <button class="btn-cancel" onclick="cancelEdit('${c._id}')">Cancel</button>
                            <button class="btn-submit" onclick="saveEdit('${c._id}')">Save</button>
                        </div>
                    </div>
                    <div class="comment-actions">
                        <button class="${hasLiked ? 'liked' : ''}" onclick="likeComment('${c._id}')"><i class="${hasLiked ? 'fas' : 'far'} fa-heart"></i> <span id="likes-${c._id}">${c.likes ? c.likes.length : 0}</span></button>
                        ${currentUserId ? `<button onclick="setReplyTarget('${c._id}', '${esc(name)}')"><i class="fas fa-reply"></i> Reply</button>` : ''}
                        ${c.replies && c.replies.filter(r => r && !r.isDeleted).length > 0 ? `<button onclick="toggleReplies('${c._id}')"><i class="fas fa-comments"></i> ${c.replies.filter(r => r && !r.isDeleted).length}</button>` : ''}
                    </div>
                    ${repliesHtml}
                </div>
            `;
        }

        function toggleMenu(id, e) {
            e.stopPropagation();
            document.querySelectorAll('.cmenu-drop').forEach(m => { if (m.id !== 'menu-' + id) m.classList.remove('show'); });
            document.getElementById('menu-' + id).classList.toggle('show');
        }
        document.addEventListener('click', () => document.querySelectorAll('.cmenu-drop').forEach(m => m.classList.remove('show')));

        function toggleReplies(id) {
            const el = document.querySelector('#comment-' + id + ' .replies');
            if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
        }
        function startEdit(id) {
            document.getElementById('text-' + id).style.display = 'none';
            document.getElementById('edit-' + id).style.display = 'block';
            document.getElementById('menu-' + id).classList.remove('show');
        }
        function cancelEdit(id) {
            document.getElementById('text-' + id).style.display = 'block';
            document.getElementById('edit-' + id).style.display = 'none';
        }
        async function saveEdit(id) {
            const text = document.getElementById('edit-text-' + id).value.trim();
            if (!text) return;
            try {
                const res = await axios.put(`/comments/${id}`, { content: text });
                if (res.data.success) {
                    document.getElementById('text-' + id).textContent = text;
                    cancelEdit(id);
                    notify.success('Updated');
                    if (document.getElementById('commentPopupPanel').classList.contains('active')) {
                        renderPopupComments();
                    }
                }
            } catch (err) { notify.error('Failed to update'); }
        }

        function openCommentPopup() {
            document.getElementById('commentPopupOverlay').classList.add('active');
            document.getElementById('commentPopupPanel').classList.add('active');
            document.body.style.overflow = 'hidden';
            renderPopupComments();
            setTimeout(() => {
                const ta = document.getElementById('popupCommentText');
                if (ta) ta.focus();
            }, 400);
        }

        function closeCommentPopup() {
            document.getElementById('commentPopupOverlay').classList.remove('active');
            document.getElementById('commentPopupPanel').classList.remove('active');
            document.body.style.overflow = '';
            clearReply();
        }

        function setReplyTarget(commentId, authorName) {
            popupReplyToId = commentId;
            document.getElementById('replyToName').textContent = authorName;
            document.getElementById('replyIndicator').style.display = 'flex';
            document.getElementById('popupCommentText').focus();
            document.getElementById('popupCommentText').placeholder = 'Write a reply...';
        }

        function clearReply() {
            popupReplyToId = null;
            document.getElementById('replyIndicator').style.display = 'none';
            document.getElementById('popupCommentText').placeholder = 'Write a comment...';
        }

        function renderPopupComments() {
            const list = document.getElementById('popupCommentsList');
            if (!allComments || allComments.length === 0) {
                list.innerHTML = '<div class="text-center text-muted py-5"><i class="far fa-comments fa-2x mb-2 d-block"></i>No comments yet. Be the first!</div>';
                return;
            }
            list.innerHTML = allComments.map(c => renderComment(c)).join('');
        }

        async function postPopupComment() {
            const text = document.getElementById('popupCommentText').value.trim();
            if (!text) return;
            const btn = document.getElementById('popupPostBtn');
            btn.disabled = true;
            try {
                const payload = { content: text };
                if (popupReplyToId) payload.parentCommentId = popupReplyToId;
                const res = await axios.post(`/comments/blog/${blogId}`, payload);
                if (res.data.success) {
                    document.getElementById('popupCommentText').value = '';
                    clearReply();
                    notify.success(popupReplyToId ? 'Reply posted!' : 'Comment posted!');
                    loadComments();
                }
            } catch (err) { notify.error('Failed to post'); }
            finally { btn.disabled = false; }
        }

        async function loadComments() {
            const list = document.getElementById('commentsList');
            list.innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin text-primary"></i></div>';
            try {
                const res = await axios.get(`/comments/blog/${blogId}`);
                if (res.data.success) {
                    allComments = res.data.comments || [];
                    const total = res.data.total || 0;
                    document.getElementById('commentCount').textContent = total;
                    document.getElementById('inlineCommentCount').textContent = total;
                    document.getElementById('popupCommentCount').textContent = total;
                    document.getElementById('statComments').textContent = total;
                    document.getElementById('fabBadgeCount').textContent = total;
                    document.getElementById('fabBadgeCount').style.display = total > 0 ? 'flex' : 'none';

                    list.innerHTML = allComments.length === 0
                        ? '<div class="text-center text-muted py-4"><i class="far fa-comments fa-2x mb-2 d-block"></i>No comments yet. Be the first!</div>'
                        : allComments.map(c => renderComment(c)).join('');

                    if (document.getElementById('commentPopupPanel').classList.contains('active')) {
                        renderPopupComments();
                    }
                }
            } catch (err) {
                list.innerHTML = '<div class="alert alert-danger">Failed to load comments. <button class="btn btn-sm btn-link" onclick="loadComments()">Retry</button></div>';
            }
        }

        async function postComment() {
            const text = document.getElementById('commentText').value.trim();
            if (!text) return;
            const btn = document.getElementById('postBtn');
            btn.disabled = true;
            try {
                const res = await axios.post(`/comments/blog/${blogId}`, { content: text });
                if (res.data.success) {
                    document.getElementById('commentText').value = '';
                    notify.success('Comment posted!');
                    loadComments();
                }
            } catch (err) { notify.error('Failed to post'); }
            finally { btn.disabled = false; }
        }

        async function postReply(parentId) {
            const text = document.getElementById('reply-text-' + parentId).value.trim();
            if (!text) return;
            try {
                const res = await axios.post(`/comments/blog/${blogId}`, { content: text, parentCommentId: parentId });
                if (res.data.success) {
                    showReply(parentId);
                    document.getElementById('reply-text-' + parentId).value = '';
                    notify.success('Reply posted!');
                    loadComments();
                }
            } catch (err) { notify.error('Failed to reply'); }
        }

        async function deleteComment(id) {
            if (!confirm('Delete this comment?')) return;
            try {
                const res = await axios.delete(`/comments/${id}`);
                if (res.data.success) { notify.success('Deleted'); loadComments(); }
            } catch (err) { notify.error('Failed to delete'); }
        }

        async function likeComment(id) {
            if (!currentUserId) { location.href = '/user/signin'; return; }
            try {
                const res = await axios.post(`/comments/${id}/like`);
                if (res.data.success) loadComments();
            } catch (err) { notify.error('Failed'); }
        }

        async function toggleLike() {
            if (!currentUserId) { location.href = '/user/signin'; return; }
            try {
                const res = await axios.post(`/blogs/${blogId}/like`);
                const d = res.data;
                if (d.success) {
                    const btn = document.getElementById('likeBtn');
                    document.getElementById('likeCount').textContent = d.likeCount;
                    document.getElementById('statLikes').textContent = d.likeCount;
                    if (d.liked) {
                        btn.classList.remove('btn-outline-danger'); btn.classList.add('btn-danger', 'liked');
                        btn.innerHTML = '<i class="fas fa-heart"></i> <span id="likeCount">' + d.likeCount + '</span>';
                    } else {
                        btn.classList.remove('btn-danger', 'liked'); btn.classList.add('btn-outline-danger');
                        btn.innerHTML = '<i class="far fa-heart"></i> <span id="likeCount">' + d.likeCount + '</span>';
                    }
                }
            } catch (err) { notify.error('Failed'); }
        }

        async function checkFollow() {
            if (!currentUserId || currentUserId === blogAuthorId) return;
            try {
                const res = await axios.get(`/follow/${blogAuthorId}/followers`);
                if (res.data.success) {
                    isFollowingAuthor = res.data.followers.some(f => f._id.toString() === currentUserId);
                    updateFollowBtn();
                }
            } catch (err) {}
        }
        function updateFollowBtn() {
            const btn = document.getElementById('followBtn');
            if (!btn) return;
            if (isFollowingAuthor) {
                btn.classList.remove('btn-primary'); btn.classList.add('btn-success');
                btn.innerHTML = '<i class="fas fa-user-check"></i> Following';
            } else {
                btn.classList.remove('btn-success'); btn.classList.add('btn-primary');
                btn.innerHTML = '<i class="fas fa-user-plus"></i> Follow';
            }
        }
        async function toggleFollow() {
            if (!currentUserId) { location.href = '/user/signin'; return; }
            try {
                const res = await axios.post(`/follow/${blogAuthorId}/follow`);
                if (res.data.success) {
                    isFollowingAuthor = res.data.following;
                    updateFollowBtn();
                    notify.success(res.data.message);
                    loadAuthorStats();
                }
            } catch (err) { notify.error('Failed'); }
        }

        async function loadAuthorStats() {
            try {
                const r1 = await axios.get(`/follow/${blogAuthorId}/followers`);
                if (r1.data.success) document.getElementById('authorFollowers').textContent = r1.data.total;
                const r2 = await axios.get(`/follow/${blogAuthorId}/following`);
                if (r2.data.success) document.getElementById('authorFollowing').textContent = r2.data.total;
            } catch (err) {}
        }

        async function deleteBlog(id) {
            if (!confirm('Delete this blog?')) return;
            try {
                const res = await axios.delete(`/blogs/${id}`);
                if (res.data.success) { notify.success('Deleted'); setTimeout(() => location.href = '/', 1500); }
            } catch (err) { notify.error('Failed'); }
        }

        function shareBlog() {
            const data = { title: '<%= blog.title %>', text: 'Check this out!', url: location.href };
            if (navigator.share) navigator.share(data);
            else if (navigator.clipboard) { navigator.clipboard.writeText(`${data.title} - ${data.url}`); notify.success('Link copied!'); }
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeCommentPopup();
        });

        document.addEventListener('DOMContentLoaded', () => {
            loadComments();
            loadAuthorStats();
            checkFollow();
            const ta = document.getElementById('commentText');
            if (ta) ta.addEventListener('input', function() { this.style.height = 'auto'; this.style.height = Math.min(this.scrollHeight, 120) + 'px'; });
            const pta = document.getElementById('popupCommentText');
            if (pta) pta.addEventListener('input', function() { this.style.height = 'auto'; this.style.height = Math.min(this.scrollHeight, 120) + 'px'; });
        });
    </script>
</body>
</html>
