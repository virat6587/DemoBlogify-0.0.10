<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Blogify - Discover amazing stories and insights from writers around the world' %>">
    <meta name="keywords" content="blog, stories, writing, articles, blogify">
    <meta name="author" content="Blogify">
    <meta name="theme-color" content="#0d6efd">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Blogify' %>">
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Discover amazing stories' %>">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'Blogify' %>">
    <title><%= typeof title !== 'undefined' ? title : 'Blogify' %></title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-theme="light">
    <div class="reading-progress" id="readingProgress" style="width: 0%"></div>
    <nav class="navbar navbar-expand-lg" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Blogify</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'home' ? 'active' : '' %>" href="/"><i class="bi bi-house"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'blogs' ? 'active' : '' %>" href="/blogs"><i class="bi bi-grid"></i> Blogs</a>
                    </li>
                    <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof activeNav !== 'undefined' && activeNav === 'write' ? 'active' : '' %>" href="/blogs/add-new"><i class="bi bi-pencil-square"></i> Write</a>
                    </li>
                    <% } %>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <form class="search-box d-none d-md-block" action="/" method="GET">
                        <i class="bi bi-search"></i>
                        <input type="search" name="search" class="form-control form-control-sm" placeholder="Search blogs..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    </form>
                    <button class="theme-toggle" id="themeToggle" title="Toggle theme"><i class="bi bi-moon-stars" id="themeIcon"></i></button>
                    <% if (locals.user) { %>
                    <a href="/notifications" class="btn btn-sm btn-light position-relative">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="notifBadge">0</span>
                    </a>
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                            <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" alt="<%= locals.user.fullName %>" class="avatar" onerror="this.src='/imgs/default.png';">
                            <span class="d-none d-lg-block fw-medium text-dark"><%= locals.user.fullName %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                            <li><a class="dropdown-item" href="/user/profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="/analytics"><i class="bi bi-graph-up me-2"></i>Analytics</a></li>
                            <li><a class="dropdown-item" href="/settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/user/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/user/signin" class="btn btn-outline-primary btn-sm">Sign In</a>
                    <a href="/user/signup" class="btn btn-primary btn-sm">Get Started</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
    <div class="toast-container" id="toastContainer"></div>
    <main class="flex-grow-1"><%- body %></main>
    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 text-muted"><i class="bi bi-journal-text text-primary"></i> <strong>Blogify</strong> &copy; <%= new Date().getFullYear() %>. Built with passion.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="#" class="text-muted me-3"><i class="bi bi-github fs-5"></i></a>
                    <a href="#" class="text-muted me-3"><i class="bi bi-twitter-x fs-5"></i></a>
                    <a href="#" class="text-muted"><i class="bi bi-linkedin fs-5"></i></a>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="/js/main.js"></script>
</body>
</html>
