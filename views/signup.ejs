<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 15px;
    }
    .signup-card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      max-width: 420px;
      width: 100%;
      padding: 1.8rem;
    }
    .otp-section {
      display: flex;
      align-items: flex-end;
      gap: 10px;
    }
    .otp-container {
      display: flex;
      gap: 6px;
      flex: 1;
    }
    .otp-box {
      width: 42px;
      height: 50px;
      text-align: center;
      font-size: 1.3rem;
      font-weight: bold;
      border: 2px solid #ddd;
      border-radius: 8px;
      outline: none;
    }
    .otp-box:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.25);
    }
    .send-otp-btn {
      height: 50px;
      padding: 0 16px;
      white-space: nowrap;
      font-weight: 500;
      flex-shrink: 0;
    }
    @media (max-width: 576px) {
      .signup-card { padding: 1.4rem; }
      .otp-box { width: 38px; height: 46px; font-size: 1.1rem; }
      .send-otp-btn { height: 46px; padding: 0 12px; font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <div class="signup-card">
    <h2 class="text-center mb-4">Create Account</h2>
    
    <form id="signupForm" action="/signup" method="POST">
      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input type="text" class="form-control" name="FullName" placeholder="John Doe" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" name="password" placeholder="••••••••" required>
      </div>

      <div class="mb-4">
        <label class="form-label">Verification Code</label>
        <div class="otp-section">
          <div class="otp-container" id="otpContainer">
            <input type="text" class="otp-box" maxlength="1" data-index="0" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="1" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="2" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="3" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="4" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
            <input type="text" class="otp-box" maxlength="1" data-index="5" oninput="moveToNext(this)" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
          </div>
          <button type="button" class="btn btn-primary send-otp-btn" id="sendOtpBtn">Send OTP</button>
        </div>
        <input type="hidden" name="otp" id="hiddenOtp">
      </div>

      <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5">Create Account</button>
    </form>

    <p class="text-center mt-3 mb-0">
      Already have an account? <a href="/login">Login</a>
    </p>
  </div>

  <script>
    function moveToNext(current) {
      const index = parseInt(current.dataset.index);
      const boxes = document.querySelectorAll('.otp-box');
      let otpValue = '';
      boxes.forEach(box => otpValue += box.value);
      document.getElementById('hiddenOtp').value = otpValue;

      if (current.value.length === 1 && index < 5) {
        boxes[index + 1].focus();
      }
    }

    // Send OTP
    document.getElementById('sendOtpBtn').addEventListener('click', async function() {
      const email = document.getElementById('email').value.trim();
      if (!email) {
        alert("Please enter your email first!");
        document.getElementById('email').focus();
        return;
      }

      this.disabled = true;
      this.textContent = "Sending...";

      try {
        const res = await fetch('/send-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json();

        if (data.success) {
          alert(`✅ OTP sent to ${email}`);
          this.textContent = "Resend OTP";
          setTimeout(() => {
            this.disabled = false;
          }, 30000);
        } else {
          alert(data.message);
          this.disabled = false;
          this.textContent = "Send OTP";
        }
      } catch (err) {
        alert("Failed to send OTP. Try again.");
        this.disabled = false;
        this.textContent = "Send OTP";
      }
    });

    // Paste OTP support
    document.getElementById('otpContainer').addEventListener('paste', function(e) {
      const pasteData = e.clipboardData.getData('text').trim();
      if (pasteData.length === 6 && /^\d{6}$/.test(pasteData)) {
        const boxes = document.querySelectorAll('.otp-box');
        pasteData.split('').forEach((digit, i) => boxes[i].value = digit);
        document.getElementById('hiddenOtp').value = pasteData;
        boxes[5].focus();
      }
    });
  </script>
</body>
</html>
