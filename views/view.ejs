<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= blog.title %> | Blogify</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    
    <style>
        .blog-container {
            max-width: 800px;
        }

        /* ========== IMPROVED TEXT SPACING ========== */
        .blog-content {
            font-size: 1.1rem;
            line-height: 1.9;
            color: #2b2b2b;
            letter-spacing: 0.3px;
        }

        .blog-content h1, .blog-content h2, .blog-content h3 {
            margin-top: 3rem;
            margin-bottom: 1.5rem;
            font-weight: 700;
            color: #111;
            letter-spacing: 0.5px;
        }

        .blog-content h1 {
            font-size: 2.5rem;
            margin-top: 4rem;
        }

        .blog-content h2 {
            font-size: 2rem;
            margin-top: 3.5rem;
            padding-top: 1rem;
            border-top: 2px solid #f0f0f0;
        }

        .blog-content h3 {
            font-size: 1.5rem;
        }

        .blog-content h4, .blog-content h5, .blog-content h6 {
            margin-top: 2rem;
            margin-bottom: 1rem;
        }

        /* Enhanced paragraph spacing */
        .blog-content p {
            margin-bottom: 2rem;
            line-height: 2;
            text-align: justify;
        }

        .blog-content p + p {
            margin-top: 2rem;
        }

        /* List improvements */
        .blog-content ul, .blog-content ol {
            margin: 2rem 0;
            padding-left: 2.5rem;
            line-height: 2;
        }

        .blog-content li {
            margin-bottom: 1rem;
            margin-left: 0.5rem;
        }

        .blog-content li + li {
            margin-top: 1.2rem;
        }

        /* Blockquote improvements */
        .blog-content blockquote {
            margin: 2.5rem 0;
            padding: 1.5rem 2rem;
            border-left: 4px solid #6366f1;
            background-color: #f8f9fa;
            font-style: italic;
            color: #555;
        }

        .blog-content img {
            max-width: 100%;
            height: auto;
            margin: 3rem 0;
            border-radius: 8px;
            display: block;
        }

        .blog-content table {
            margin: 2.5rem 0;
            width: 100%;
            border-collapse: collapse;
        }

        .blog-content table th,
        .blog-content table td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .blog-content table th {
            background-color: #f8f9fa;
            font-weight: 600;
        }

        /* =========================================================
           CODE BLOCK WRAPPER (Dark box + badge + footer + enhanced scrolling)
           ========================================================= */
        .code-block-wrapper {
            position: relative;
            background: #1e1e1e;
            border-radius: 12px;
            overflow: hidden;
            margin: 2.5rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border: 1px solid #2d2d2d;
        }
        
        /* Language badge top-left */
        .code-lang-badge {
            display: inline-block;
            background: linear-gradient(135deg, #2d2d2d, #3a3a3a);
            color: #e0e0e0;
            font-family: 'Fira Code', Consolas, Monaco, monospace;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 8px 16px;
            border-bottom-right-radius: 8px;
            border-top-left-radius: 12px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            z-index: 10;
            position: relative;
        }
        
        /* Scrollable code area - Support for 10,000+ lines */
        .blog-content pre {
            background-color: #1e1e1e !important;
            padding: 2rem 1.5rem;
            margin: 0;
            border-radius: 0;
            box-shadow: none;
            border: none;
            
            max-height: 600px !important; 
            overflow-y: auto !important;
            overflow-x: auto !important;
            display: block;
            
            will-change: transform;
            -webkit-overflow-scrolling: touch;
            overscroll-behavior: contain;
            contain: paint layout style;
            scroll-behavior: smooth;
        }

        /* Enhanced scrollbar styling */
        .blog-content pre::-webkit-scrollbar {
            width: 12px;
            height: 12px;
        }

        .blog-content pre::-webkit-scrollbar-track {
            background: #1e1e1e;
            border-radius: 10px;
        }

        .blog-content pre::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #3c3c3c, #4b4b4b);
            border-radius: 10px;
            border: 2px solid #1e1e1e;
        }

        .blog-content pre::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #4b4b4b, #5a5a5a);
        }

        /* Firefox scrollbar */
        .blog-content pre {
            scrollbar-width: thin;
            scrollbar-color: #3c3c3c #1e1e1e;
        }
        
        /* Code typography */
        .blog-content pre code {
            font-family: 'Fira Code', 'Monaco', 'Consolas', 'Courier New', monospace !important;
            font-size: 0.9rem;
            background-color: transparent !important;
            padding: 0;
            display: block;
            line-height: 1.7;
            tab-size: 4;
            -moz-tab-size: 4;
            white-space: pre !important; 
            word-break: normal !important;
            word-wrap: normal !important;
            color: #d4d4d4;
        }

        /* Footer bar */
        .code-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(90deg, #1e1e1e, #222222);
            padding: 12px 16px;
            border-top: 1px solid #2d2d2d;
            font-size: 0.82rem;
            color: #9e9e9e;
            z-index: 10;
            position: relative;
        }
        
        .code-footer .caution-text {
            font-style: italic;
            font-size: 0.8rem;
        }

        .code-footer .line-count {
            font-size: 0.8rem;
            color: #6a6a6a;
        }
        
        .code-footer .copy-btn {
            background: transparent;
            border: 1px solid #3c3c3c;
            color: #9e9e9e;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 6px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .code-footer .copy-btn:hover {
            background: #2d2d2d;
            color: #fff;
            border-color: #4a4a4a;
        }

        .code-footer .copy-btn.copied {
            color: #4ade80;
            border-color: #4ade80;
        }

        /* ========== VIBRANT SYNTAX COLORS ========== */
        .hljs {
            color: #d4d4d4 !important;
            background-color: #1e1e1e !important;
        }

        /* Keywords - Purple */
        .hljs-keyword, .hljs-selector-tag, .hljs-built_in, .hljs-builtin-name { 
            color: #c586c0 !important; 
            font-weight: normal; 
        }

        /* Strings - Orange */
        .hljs-string, .hljs-meta .hljs-string { 
            color: #ce9178 !important; 
        }

        /* Function names and titles - Yellow */
        .hljs-title, .hljs-section, .hljs-function, .hljs-function-name { 
            color: #dcdcaa !important; 
        }

        /* Variables - Blue */
        .hljs-variable, .hljs-template-variable, .hljs-params, .hljs-name { 
            color: #9cdcfe !important; 
        }

        /* Comments - Green */
        .hljs-comment, .hljs-quote { 
            color: #6a9955 !important; 
            font-style: italic; 
        }

        /* Numbers and attributes - Light Blue */
        .hljs-attr, .hljs-number, .hljs-literal { 
            color: #9cdcfe !important; 
        }

        /* Tags - Blue */
        .hljs-tag, .hljs-type, .hljs-doctag { 
            color: #569cd6 !important; 
        }

        /* Properties - Teal */
        .hljs-property, .hljs-regexp, .hljs-symbol { 
            color: #4ec9b0 !important; 
        }

        /* Operators */
        .hljs-operator {
            color: #d4d4d4 !important;
        }

        /* Language specific */
        .hljs-meta {
            color: #9cdcfe !important;
        }

        .hljs-literal {
            color: #569cd6 !important;
        }

        /* Inline code in paragraphs */
        .blog-content p code,
        .blog-content li code,
        .blog-content td code {
            background-color: #f1f3f5;
            color: #d63384;
            border-radius: 4px;
            padding: 0.3rem 0.6rem;
            font-family: 'Fira Code', Consolas, Monaco, 'Courier New', monospace;
            font-size: 0.9em;
            border: 1px solid #e9ecef;
        }

        .sidebar-widget {
            position: sticky;
            top: 100px;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .blog-content {
                font-size: 1rem;
            }

            .blog-content h1 {
                font-size: 1.8rem;
            }

            .blog-content h2 {
                font-size: 1.5rem;
            }

            .blog-content p {
                margin-bottom: 1.5rem;
            }

            .blog-content pre {
                max-height: 500px !important;
                padding: 1.5rem 1rem !important;
            }

            .code-footer {
                flex-direction: column;
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <article class="container my-5">
        <div class="row">
            <div class="col-lg-8">
                <a href="/" class="btn btn-outline-primary btn-sm mb-4">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>

                <div class="mb-5">
                    <h1 class="display-5 fw-bold mb-3"><%= blog.title %></h1>

                    <div class="d-flex align-items-center justify-content-between py-3 border-top border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <img src="<%= blog.createdBy.profileImageURL %>" 
                                 alt="<%= blog.createdBy.fullName %>" 
                                 width="48" height="48" 
                                 class="rounded-circle"
                                 onerror="this.src='/imgs/default.png';">
                            <div>
                                <a href="#" class="fw-bold text-decoration-none" id="authorLink">
                                    <%= blog.createdBy.fullName %>
                                </a>
                                <div class="small text-muted">
                                    <%= formatDate(blog.createdAt) %> 
                                    <% if (blog.readingTime) { %>
                                        • <%= blog.readingTime %> min read
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <% if (locals.user && locals.user._id == blog.createdBy._id) { %>
                                <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteBlog('<%= blog._id %>')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>

                <% if (blog.coverImageURL) { %>
                    <img src="<%= blog.coverImageURL %>" 
                         alt="<%= blog.title %>" 
                         class="img-fluid rounded-3 mb-5 shadow-sm"
                         onerror="this.src='/images/default-blog.png';">
                <% } %>

                <div class="blog-content mb-5">
                    <%- renderMarkdown(blog.body) %>
                </div>

                <% if (blog.tags && blog.tags.length > 0) { %>
                    <div class="mb-5 pb-4 border-bottom">
                        <h6 class="fw-bold mb-3">Tags</h6>
                        <div>
                            <% blog.tags.forEach(tag => { %>
                                <a href="/blogs/tags/<%= tag %>" class="btn btn-sm btn-outline-primary me-2 mb-2">
                                    #<%= tag %>
                                </a>
                            <% }) %>
                        </div>
                    </div>
                <% } %>

                <div class="d-flex gap-3 py-4 border-top border-bottom">
                    <button class="btn btn-outline-danger" id="likeBtn" onclick="toggleLike()">
                        <i class="fas fa-heart <%= hasLiked ? 'fas' : 'far' %>"></i>
                        <span id="likeCount"><%= blog.likes ? blog.likes.length : 0 %></span>
                        Like
                    </button>
                    <button class="btn btn-outline-primary" id="shareBtn">
                        <i class="fas fa-share-alt"></i> Share
                    </button>
                </div>

                <div class="mt-5">
                    <h4 class="fw-bold mb-4">
                        <i class="fas fa-comments"></i> Comments
                    </h4>

                    <% if (locals.user) { %>
                        <div class="card mb-4">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3">Leave a Comment</h6>
                                <form id="commentForm">
                                    <textarea class="form-control mb-3" id="commentContent" 
                                              rows="3" placeholder="Share your thoughts..."
                                              required></textarea>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-comment"></i> Post Comment
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> 
                            <a href="/user/signin">Sign in</a> to leave a comment
                        </div>
                    <% } %>

                    <div id="commentsList"></div>
                </div>
            </div>

            <div class="col-lg-4 mt-5 mt-lg-0">
                <div class="card shadow-sm sidebar-widget mb-4">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <img src="<%= blog.createdBy.profileImageURL %>" 
                                 alt="<%= blog.createdBy.fullName %>" 
                                 width="80" height="80" 
                                 class="rounded-circle mb-3"
                                 onerror="this.src='/imgs/default.png';">
                            <h5 class="fw-bold"><%= blog.createdBy.fullName %></h5>
                            <p class="text-muted small mb-3"><%= blog.createdBy.bio || 'Blogger' %></p>
                        </div>

                        <div class="d-flex justify-content-around text-center mb-3">
                            <div>
                                <h6 class="fw-bold">0</h6>
                                <small class="text-muted">Followers</small>
                            </div>
                            <div>
                                <h6 class="fw-bold">0</h6>
                                <small class="text-muted">Following</small>
                            </div>
                        </div>

                        <% if (locals.user && locals.user._id != blog.createdBy._id) { %>
                            <button class="btn btn-primary w-100" id="followBtn" onclick="toggleFollow()">
                                <i class="fas fa-user-plus"></i> Follow
                            </button>
                        <% } %>
                    </div>
                </div>

                <div class="card shadow-sm sidebar-widget mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Stats</h6>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted"><i class="fas fa-eye"></i> Views</span>
                            <strong><%= blog.viewCount || 0 %></strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted"><i class="fas fa-heart"></i> Likes</span>
                            <strong><%= blog.likes ? blog.likes.length : 0 %></strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted"><i class="fas fa-comment"></i> Comments</span>
                            <strong id="commentCount">0</strong>
                        </div>
                    </div>
                </div>

                <% if (typeof relatedBlogs !== 'undefined' && relatedBlogs.length > 0) { %>
                    <div class="card shadow-sm sidebar-widget">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3">Related Articles</h6>
                            <% relatedBlogs.forEach(relatedBlog => { %>
                                <a href="/blogs/<%= relatedBlog._id %>" class="text-decoration-none d-block mb-2 p-2" style="border-left: 3px solid #6366f1; padding-left: 1rem;">
                                    <small class="fw-bold text-dark">
                                        <%= truncate(relatedBlog.title, 50) %>
                                    </small>
                                </a>
                            <% }) %>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </article>

    <%- include("./partials/scripts") %>

    <script>
        const blogId = '<%= blog._id %>';
        const currentUserId = '<%= locals.user ? locals.user._id : "" %>';

        /* =========================================================
           WRAP CODE BLOCKS WITH BADGE + FOOTER + COPY BUTTON
           Supports all code languages and handles 10,000+ lines
           ========================================================= */
        function initCodeBlocks() {
            document.querySelectorAll('.blog-content pre').forEach(pre => {
                if (pre.parentElement && pre.parentElement.classList.contains('code-block-wrapper')) return;

                const code = pre.querySelector('code');
                if (!code) return;

                // Detect language from class: "hljs language-javascript"
                let lang = 'code';
                const langMatch = code.className.match(/language-(\w+)/);
                if (langMatch) {
                    lang = langMatch[1].toLowerCase();
                }

                // Count lines for display
                const lineCount = (code.innerText.match(/\n/g) || []).length + 1;

                const wrapper = document.createElement('div');
                wrapper.className = 'code-block-wrapper';

                const badge = document.createElement('div');
                badge.className = 'code-lang-badge';
                badge.textContent = lang;

                const footer = document.createElement('div');
                footer.className = 'code-footer';
                footer.innerHTML = `
                    <span class="caution-text">Use code with caution.</span>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <span class="line-count">${lineCount} lines</span>
                        <button class="copy-btn" aria-label="Copy code">
                            <i class="far fa-copy"></i> <span>Copy</span>
                        </button>
                    </div>
                `;

                const copyBtn = footer.querySelector('.copy-btn');
                copyBtn.addEventListener('click', async () => {
                    try {
                        await navigator.clipboard.writeText(code.innerText);
                        copyBtn.classList.add('copied');
                        copyBtn.innerHTML = '<i class="fas fa-check"></i> <span>Copied!</span>';
                        setTimeout(() => {
                            copyBtn.classList.remove('copied');
                            copyBtn.innerHTML = '<i class="far fa-copy"></i> <span>Copy</span>';
                        }, 2000);
                    } catch (err) {
                        // Fallback for older browsers
                        try {
                            const range = document.createRange();
                            range.selectNode(code);
                            window.getSelection().removeAllRanges();
                            window.getSelection().addRange(range);
                            document.execCommand('copy');
                            window.getSelection().removeAllRanges();
                            copyBtn.classList.add('copied');
                            copyBtn.innerHTML = '<i class="fas fa-check"></i> <span>Copied!</span>';
                            setTimeout(() => {
                                copyBtn.classList.remove('copied');
                                copyBtn.innerHTML = '<i class="far fa-copy"></i> <span>Copy</span>';
                            }, 2000);
                        } catch (fallbackErr) {
                            console.error('Copy failed:', fallbackErr);
                        }
                    }
                });

                pre.parentNode.insertBefore(wrapper, pre);
                wrapper.appendChild(badge);
                wrapper.appendChild(pre);
                wrapper.appendChild(footer);
            });
        }

        async function toggleLike() {
            if (!currentUserId) {
                window.location.href = '/user/signin';
                return;
            }
            try {
                const res = await axios.post(`/blogs/${blogId}/like`);
                const data = res.data;
                if (data.success) {
                    const likeBtn = document.getElementById('likeBtn');
                    const likeCount = document.getElementById('likeCount');
                    likeCount.textContent = data.likeCount;
                    if (data.liked) {
                        likeBtn.innerHTML = '<i class="fas fa-heart"></i> <span id="likeCount">' + data.likeCount + '</span> Like';
                        likeBtn.classList.add('btn-danger');
                        likeBtn.classList.remove('btn-outline-danger');
                    } else {
                        likeBtn.innerHTML = '<i class="far fa-heart"></i> <span id="likeCount">' + data.likeCount + '</span> Like';
                        likeBtn.classList.remove('btn-danger');
                        likeBtn.classList.add('btn-outline-danger');
                    }
                }
            } catch (err) {
                notify.error('Failed to like blog');
            }
        }

        async function toggleFollow() {
            if (!currentUserId) {
                window.location.href = '/user/signin';
                return;
            }
            try {
                const res = await axios.post(`/follow/<%= blog.createdBy._id %>/follow`);
                const data = res.data;
                if (data.success) {
                    const followBtn = document.getElementById('followBtn');
                    if (data.following) {
                        followBtn.innerHTML = '<i class="fas fa-user-check"></i> Following';
                        followBtn.classList.add('btn-success');
                        followBtn.classList.remove('btn-primary');
                    } else {
                        followBtn.innerHTML = '<i class="fas fa-user-plus"></i> Follow';
                        followBtn.classList.remove('btn-success');
                        followBtn.classList.add('btn-primary');
                    }
                    notify.success(data.message);
                }
            } catch (err) {
                notify.error('Failed to follow user');
            }
        }

        async function loadComments() {
            try {
                const res = await axios.get(`/comments/blog/${blogId}`);
                const data = res.data;
                if (data.success) {
                    document.getElementById('commentCount').textContent = data.total;
                    const commentsList = document.getElementById('commentsList');
                    if (data.comments.length === 0) {
                        commentsList.innerHTML = '<p class="text-muted">No comments yet. Be the first to comment!</p>';
                        return;
                    }
                    commentsList.innerHTML = data.comments.map(comment => `
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex gap-2">
                                        <img src="${comment.author.profileImageURL}" 
                                             width="40" height="40" 
                                             class="rounded-circle"
                                             onerror="this.src='/imgs/default.png';">
                                        <div>
                                            <h6 class="fw-bold mb-0">${comment.author.fullName}</h6>
                                            <small class="text-muted">${timeAgo(comment.createdAt)}</small>
                                        </div>
                                    </div>
                                    <button class="btn btn-link btn-sm" onclick="toggleCommentLike('${comment._id}')">
                                        <i class="far fa-heart"></i> ${comment.likeCount || 0}
                                    </button>
                                </div>
                                <p class="mb-2">${comment.content}</p>
                                <button class="btn btn-link btn-sm" onclick="toggleCommentReply('${comment._id}')">
                                    <i class="fas fa-reply"></i> Reply
                                </button>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (err) {
                console.error('Error loading comments:', err);
            }
        }

        <% if (locals.user) { %>
            document.getElementById('commentForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const content = document.getElementById('commentContent').value.trim();
                if (!content) return;
                try {
                    const res = await axios.post(`/comments/blog/${blogId}`, { content });
                    if (res.data.success) {
                        document.getElementById('commentContent').value = '';
                        notify.success('Comment posted successfully!');
                        loadComments();
                    }
                } catch (err) {
                    notify.error('Failed to post comment');
                }
            });
        <% } %>

        document.getElementById('shareBtn').addEventListener('click', () => {
            const shareData = {
                title: '<%= blog.title %>',
                text: 'Check out this amazing blog!',
                url: window.location.href
            };
            if (navigator.share) {
                navigator.share(shareData);
            } else {
                const url = window.location.href;
                const text = `Check out: ${shareData.title} - ${url}`;
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(text);
                    notify.success('Link copied to clipboard!');
                }
            }
        });

        async function deleteBlog(id) {
            if (!await confirmAction('Are you sure you want to delete this blog?')) return;
            try {
                const res = await axios.delete(`/blogs/${id}`);
                if (res.data.success) {
                    notify.success('Blog deleted successfully!');
                    setTimeout(() => window.location.href = '/', 2000);
                }
            } catch (err) {
                notify.error('Failed to delete blog');
            }
        }

        async function toggleCommentLike(commentId) {
            if (!currentUserId) {
                window.location.href = '/user/signin';
                return;
            }
            try {
                const res = await axios.post(`/comments/${commentId}/like`);
                if (res.data.success) {
                    loadComments();
                }
            } catch (err) {
                notify.error('Failed to like comment');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            initCodeBlocks();
            loadComments();
        });
    </script>
</body>
</html>
