<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifications - Blogify</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    body { background: #f3f4f6; }
    
    .notif-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
    
    .notif-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }
    
    .notif-header h4 {
      font-weight: 700;
      margin: 0;
    }
    
    /* Swipe Container */
    .swipe-item {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      margin-bottom: 0.75rem;
      touch-action: pan-y;
    }
    
    .swipe-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: #ef4444;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 2rem;
      color: white;
      font-weight: 600;
      z-index: 1;
    }
    
    .swipe-bg i {
      font-size: 1.5rem;
    }
    
    .swipe-content {
      position: relative;
      background: white;
      z-index: 2;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      border-radius: 16px;
      cursor: grab;
    }
    
    .swipe-content.swiped {
      transform: translateX(-120px);
    }
    
    .swipe-content:active {
      cursor: grabbing;
    }
    
    .notif-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
    }
    
    .notif-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    
    .notif-body {
      flex: 1;
      min-width: 0;
    }
    
    .notif-title {
      font-weight: 600;
      margin-bottom: 0.25rem;
      color: #1f2937;
    }
    
    .notif-message {
      color: #6b7280;
      font-size: 0.875rem;
      margin-bottom: 0.25rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .notif-time {
      font-size: 0.75rem;
      color: #9ca3af;
    }
    
    .notif-unread {
      width: 10px;
      height: 10px;
      background: #4f46e5;
      border-radius: 50%;
      flex-shrink: 0;
    }
    
    .notif-blog-img {
      width: 60px;
      height: 60px;
      border-radius: 12px;
      object-fit: cover;
      flex-shrink: 0;
    }
    
    /* Follow Request Actions */
    .request-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    
    .btn-accept {
      background: #10b981;
      color: white;
      border: none;
      padding: 0.4rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
    }
    
    .btn-reject {
      background: transparent;
      color: #ef4444;
      border: 1px solid #ef4444;
      padding: 0.4rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
    }
    
    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 5rem 2rem;
    }
    
    .empty-state i {
      font-size: 5rem;
      color: #d1d5db;
    }
    
    /* Delete button revealed on swipe */
    .delete-btn {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 120px;
      background: #ef4444;
      color: white;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      z-index: 3;
      border-radius: 0 16px 16px 0;
    }
    
    @media (max-width: 576px) {
      .notif-container { padding: 1rem; }
      .notif-card { padding: 1rem; }
      .notif-avatar { width: 40px; height: 40px; }
    }
  </style>
</head>
<body>

  <%- include('./partials/nav') %>

  <div class="notif-container">
    
    <div class="notif-header">
      <div>
        <h4><i class="bi bi-bell-fill me-2 text-primary"></i>Notifications</h4>
        <p class="text-muted mb-0 small">Swipe left to delete</p>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="markAllRead()">
          <i class="bi bi-check-all"></i> Mark All Read
        </button>
        <button class="btn btn-outline-danger btn-sm" onclick="clearRead()">
          <i class="bi bi-trash"></i> Clear Read
        </button>
      </div>
    </div>

    <!-- Follow Requests Section (if any) -->
    <% if (grouped.follow_requests && grouped.follow_requests.length > 0) { %>
      <div class="mb-4">
        <h6 class="fw-bold mb-3 text-warning"><i class="bi bi-person-plus-fill me-2"></i>Follow Requests</h6>
        <% grouped.follow_requests.forEach(notif => { %>
          <div class="swipe-item" data-id="<%= notif._id %>">
            <div class="swipe-bg">
              <i class="bi bi-trash3"></i>
            </div>
            <div class="swipe-content">
              <div class="notif-card">
                <img src="<%= notif.requester?.profileImageURL || '/imgs/default.png' %>" class="notif-avatar" alt="">
                <div class="notif-body">
                  <div class="notif-title"><%= notif.title %></div>
                  <div class="notif-message"><%= notif.message %></div>
                  <div class="notif-time"><%= formatDate(notif.createdAt) %></div>
                  <div class="request-actions">
                    <button class="btn-accept" onclick="handleRequest('<%= notif.requester?._id %>', 'accept', '<%= notif._id %>')">
                      <i class="bi bi-check-lg me-1"></i> Accept
                    </button>
                    <button class="btn-reject" onclick="handleRequest('<%= notif.requester?._id %>', 'reject', '<%= notif._id %>')">
                      <i class="bi bi-x-lg me-1"></i> Reject
                    </button>
                  </div>
                </div>
                <% if (!notif.isRead) { %>
                  <div class="notif-unread"></div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- All Notifications -->
    <% if (!notifications || notifications.length === 0) { %>
      <div class="empty-state bg-white rounded-4 shadow-sm">
        <i class="bi bi-bell"></i>
        <h5 class="mt-3 text-muted">No notifications yet</h5>
        <p class="text-muted">When someone interacts with you, you'll see it here</p>
      </div>
    <% } else { %>
      <div id="notificationsList">
        <% notifications.forEach(notif => { %>
          <% if (notif.type !== 'follow_request' || notif.requestStatus !== 'pending') { %>
            <div class="swipe-item" data-id="<%= notif._id %>">
              <div class="swipe-bg">
                <i class="bi bi-trash3"></i>
              </div>
              <div class="swipe-content" onclick="handleNotifClick('<%= notif._id %>', '<%= notif.type %>', '<%= notif.blog?._id || notif.actor?._id %>')">
                <div class="notif-card">
                  <!-- Actor Avatar -->
                  <img src="<%= notif.actor?.profileImageURL || '/imgs/default.png' %>" class="notif-avatar" alt="">
                  
                  <div class="notif-body">
                    <div class="notif-title">
                      <% if (notif.type === 'like') { %>
                        <i class="bi bi-heart-fill text-danger me-1"></i>
                      <% } else if (notif.type === 'comment') { %>
                        <i class="bi bi-chat-fill text-primary me-1"></i>
                      <% } else if (notif.type === 'follow') { %>
                        <i class="bi bi-person-plus-fill text-success me-1"></i>
                      <% } else if (notif.type === 'follow_accepted') { %>
                        <i class="bi bi-person-check-fill text-success me-1"></i>
                      <% } else if (notif.type === 'new_blog') { %>
                        <i class="bi bi-journal-text text-info me-1"></i>
                      <% } %>
                      <%= notif.title %>
                    </div>
                    <div class="notif-message"><%= notif.message %></div>
                    <div class="notif-time"><%= formatDate(notif.createdAt) %></div>
                  </div>

                  <!-- Blog Image for new_blog -->
                  <% if (notif.type === 'new_blog' && notif.blogImageURL) { %>
                    <img src="<%= notif.blogImageURL %>" class="notif-blog-img" alt="">
                  <% } %>

                  <% if (!notif.isRead) { %>
                    <div class="notif-unread"></div>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
    <% } %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ==================== SWIPE TO DELETE ====================
    document.querySelectorAll('.swipe-item').forEach(item => {
      const content = item.querySelector('.swipe-content');
      let startX = 0;
      let currentX = 0;
      let isDragging = false;
      const threshold = -80;

      // Touch events
      content.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
        content.style.transition = 'none';
      });

      content.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        currentX = e.touches[0].clientX - startX;
        if (currentX < 0) {
          content.style.transform = `translateX(${currentX}px)`;
        }
      });

      content.addEventListener('touchend', () => {
        isDragging = false;
        content.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
        if (currentX < threshold) {
          content.style.transform = 'translateX(-120px)';
          // Show delete confirmation after swipe
          setTimeout(() => {
            if (confirm('Delete this notification?')) {
              deleteNotification(item.dataset.id);
            } else {
              content.style.transform = 'translateX(0)';
            }
          }, 300);
        } else {
          content.style.transform = 'translateX(0)';
        }
        currentX = 0;
      });

      // Mouse events (for desktop testing)
      content.addEventListener('mousedown', (e) => {
        startX = e.clientX;
        isDragging = true;
        content.style.transition = 'none';
      });

      content.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        currentX = e.clientX - startX;
        if (currentX < 0) {
          content.style.transform = `translateX(${currentX}px)`;
        }
      });

      content.addEventListener('mouseup', () => {
        isDragging = false;
        content.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
        if (currentX < threshold) {
          content.style.transform = 'translateX(-120px)';
          setTimeout(() => {
            if (confirm('Delete this notification?')) {
              deleteNotification(item.dataset.id);
            } else {
              content.style.transform = 'translateX(0)';
            }
          }, 300);
        } else {
          content.style.transform = 'translateX(0)';
        }
        currentX = 0;
      });

      content.addEventListener('mouseleave', () => {
        if (isDragging) {
          isDragging = false;
          content.style.transform = 'translateX(0)';
        }
      });
    });

    // ==================== HANDLE NOTIFICATION CLICK ====================
    async function handleNotifClick(notifId, type, targetId) {
      // Mark as read
      await fetch(`/notifications/${notifId}/read`, { method: 'PUT' });

      // Navigate based on type
      switch (type) {
        case 'like':
        case 'comment':
          window.location.href = `/blogs/${targetId}`;
          break;
        case 'follow':
        case 'follow_accepted':
          window.location.href = `/user/profile/${targetId}`;
          break;
        case 'new_blog':
          window.location.href = `/blogs/${targetId}`;
          break;
        default:
          window.location.reload();
      }
    }

    // ==================== HANDLE FOLLOW REQUEST ====================
    async function handleRequest(userId, action, notifId) {
      event.stopPropagation();
      try {
        const res = await fetch(`/follow/${userId}/${action}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          // Delete the notification after handling
          await deleteNotification(notifId, false);
          window.location.reload();
        } else {
          alert(data.message);
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }

    // ==================== DELETE NOTIFICATION ====================
    async function deleteNotification(notifId, confirm = true) {
      if (confirm && !window.confirm('Delete this notification?')) return;
      
      try {
        const res = await fetch(`/notifications/${notifId}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          const item = document.querySelector(`[data-id="${notifId}"]`);
          if (item) {
            item.style.transition = 'all 0.3s';
            item.style.opacity = '0';
            item.style.transform = 'translateX(-100%)';
            setTimeout(() => item.remove(), 300);
          }
        }
      } catch (err) {
        console.error('Delete error:', err);
      }
    }

    // ==================== MARK ALL READ ====================
    async function markAllRead() {
      try {
        await fetch('/notifications/all/read', { method: 'PUT' });
        document.querySelectorAll('.notif-unread').forEach(el => el.remove());
        alert('All notifications marked as read');
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }

    // ==================== CLEAR READ ====================
    async function clearRead() {
      if (!confirm('Clear all read notifications?')) return;
      try {
        const res = await fetch('/notifications/clear/read', { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          window.location.reload();
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
  </script>
</body>
</html>
