<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Error | Blogify</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
        <div class="text-center">
            <div class="mb-4">
                <i class="fas fa-exclamation-triangle fa-5x text-danger"></i>
            </div>
            
            <h1 class="display-4 fw-bold mb-3">Oops! Something Went Wrong</h1>
            
            <p class="lead text-muted mb-4">
                We encountered an unexpected error. Please try again later or contact support.
            </p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger mt-4" role="alert">
                    <strong>Error Details:</strong>
                    <p class="mb-0"><%= error.message || error %></p>
                </div>
            <% } %>

            <div class="mt-5">
                <a href="/" class="btn btn-primary btn-lg me-3">
                    <i class="fas fa-home"></i> Back to Home
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-primary btn-lg">
                    <i class="fas fa-arrow-left"></i> Go Back
                </a>
            </div>

            <div class="mt-5 pt-5">
                <p class="text-muted small">
                    Error Code: <%= typeof error !== 'undefined' && error.code ? error.code : '500' %>
                </p>
            </div>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        console.error('<%= typeof error !== "undefined" ? error.message : "Unknown error" %>');
    </script>
</body>
</html>
