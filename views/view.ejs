<body>
    <%- include("./partials/nave") %>

    <div class="container my-4">
        <div class="row">
            <div class="col-lg-8">
                <a href="/" class="btn btn-outline-primary btn-sm mb-3"><i class="fas fa-arrow-left"></i> Back</a>
                <h1 class="fw-bold mb-3"><%= blog.title %></h1>
                <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
                    <img src="<%= blog.createdBy.profileImageURL %>" width="44" height="44" class="rounded-circle" onerror="this.src='/imgs/default.png';">
                    <div>
                        <div class="fw-bold"><%= blog.createdBy.fullName %></div>
                        <small class="text-muted"><%= formatDate(blog.createdAt) %> • <%= blog.readingTime || 0 %> min read • <%= blog.viewCount || 0 %> views</small>
                    </div>
                    <% if (locals.user && locals.user._id.toString() === blog.createdBy._id.toString()) { %>
                        <div class="ms-auto">
                            <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-outline-danger btn-sm" onclick="deleteBlog('<%= blog._id %>')"><i class="fas fa-trash"></i></button>
                        </div>
                    <% } %>
                </div>

                <% if (blog.coverImageURL) { %>
                    <img src="<%= blog.coverImageURL %>" class="img-fluid rounded-3 mb-4 w-100" style="max-height: 400px; object-fit: cover;" onerror="this.style.display='none';">
                <% } %>

                <div class="blog-body mb-5">
                    <%- renderMarkdown(blog.body) %>
                </div>

                <% if (blog.tags && blog.tags.length > 0) { %>
                    <div class="mb-4">
                        <% blog.tags.forEach(tag => { %>
                            <a href="/blogs/tags/<%= tag %>" class="badge bg-primary-soft text-primary me-1 mb-1" style="text-decoration:none;">#<%= tag %></a>
                        <% }) %>
                    </div>
                <% } %>

                <div class="d-flex gap-2 mb-5 pb-4 border-bottom">
                    <button class="btn <%= hasLiked ? 'btn-danger' : 'btn-outline-danger' %> like-btn" id="likeBtn" onclick="toggleLike()">
                        <i class="<%= hasLiked ? 'fas' : 'far' %> fa-heart"></i> <span id="likeCount"><%= blog.likes ? blog.likes.length : 0 %></span>
                    </button>
                    <button class="btn btn-outline-primary" onclick="shareBlog()"><i class="fas fa-share-alt"></i> Share</button>
                    <button class="btn btn-outline-primary" onclick="openCommentPopup()">
                        <i class="fas fa-comment"></i> <span id="inlineCommentCount">0</span>
                    </button>
                </div>

                <h4 class="fw-bold mb-3"><i class="fas fa-comments text-primary"></i> Comments <span class="badge bg-primary-soft text-primary" id="commentCount">0</span></h4>

                <% if (locals.user) { %>
                    <div class="comment-input-area">
                        <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" onerror="this.src='/imgs/default.png';">
                        <textarea id="commentText" placeholder="Write a comment..." rows="1"></textarea>
                        <button onclick="postComment()" id="postBtn"><i class="fas fa-paper-plane"></i></button>
                    </div>
                <% } else { %>
                    <div class="alert alert-light text-center mb-4"><a href="/user/signin" class="btn btn-primary btn-sm">Sign in to comment</a></div>
                <% } %>

                <div id="commentsList"></div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="sidebar">
                    <div class="stat-card text-center">
                        <img src="<%= blog.createdBy.profileImageURL %>" width="70" height="70" class="rounded-circle mb-2" onerror="this.src='/imgs/default.png';">
                        <h5 class="fw-bold mb-1"><%= blog.createdBy.fullName %></h5>
                        <p class="text-muted small mb-3"><%= blog.createdBy.bio || 'Blogger' %></p>
                        <div class="d-flex justify-content-around text-center mb-3">
                            <div><h6 class="fw-bold mb-0" id="authorFollowers">0</h6><small class="text-muted">Followers</small></div>
                            <div><h6 class="fw-bold mb-0" id="authorFollowing">0</h6><small class="text-muted">Following</small></div>
                            <div><h6 class="fw-bold mb-0"><%= authorBlogs ? authorBlogs.length : 0 %></h6><small class="text-muted">Posts</small></div>
                        </div>
                        <% if (locals.user && locals.user._id.toString() !== blog.createdBy._id.toString()) { %>
                            <button class="btn btn-primary w-100" id="followBtn" onclick="toggleFollow()"><i class="fas fa-user-plus"></i> Follow</button>
                        <% } %>
                    </div>

                    <div class="stat-card">
                        <h6 class="fw-bold mb-3"><i class="fas fa-chart-bar text-primary"></i> Stats</h6>
                        <div class="d-flex justify-content-between mb-2"><span class="text-muted"><i class="fas fa-eye"></i> Views</span><strong id="statViews"><%= blog.viewCount || 0 %></strong></div>
                        <div class="d-flex justify-content-between mb-2"><span class="text-muted"><i class="fas fa-heart text-danger"></i> Likes</span><strong id="statLikes"><%= blog.likes ? blog.likes.length : 0 %></strong></div>
                        <div class="d-flex justify-content-between"><span class="text-muted"><i class="fas fa-comment text-primary"></i> Comments</span><strong id="statComments">0</strong></div>
                    </div>

                    <% if (authorBlogs && authorBlogs.length > 0) { %>
                        <div class="stat-card">
                            <h6 class="fw-bold mb-3"><i class="fas fa-pen text-primary"></i> More from <%= blog.createdBy.fullName %></h6>
                            <% authorBlogs.forEach(b => { %>
                                <a href="/blogs/<%= b._id %>" class="text-decoration-none d-block mb-2 p-2 rounded" style="background:#f8fafc;">
                                    <small class="fw-bold text-dark d-block"><%= truncate(b.title, 45) %></small>
                                    <small class="text-muted" style="font-size:0.7rem;"><%= formatDate(b.createdAt) %></small>
                                </a>
                            <% }) %>
                        </div>
                    <% } %>

                    <% if (relatedBlogs && relatedBlogs.length > 0) { %>
                        <div class="stat-card">
                            <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb text-warning"></i> Related</h6>
                            <% relatedBlogs.forEach(b => { %>
                                <a href="/blogs/<%= b._id %>" class="text-decoration-none d-block mb-2 p-2 rounded" style="background:#f0fdf4;">
                                    <small class="fw-bold text-dark d-block"><%= truncate(b.title, 45) %></small>
                                    <small class="text-muted" style="font-size:0.7rem;"><%= formatDate(b.createdAt) %></small>
                                </a>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="comment-popup-overlay" id="commentPopupOverlay" onclick="closeCommentPopup()"></div>
    <div class="comment-popup-panel" id="commentPopupPanel">
        <div class="comment-popup-header">
            <h5><i class="fas fa-comments text-primary me-2"></i>Comments <span class="badge bg-primary-soft text-primary" id="popupCommentCount">0</span></h5>
            <button class="close-btn" onclick="closeCommentPopup()"><i class="fas fa-times"></i></button>
        </div>
        <div class="comment-popup-body" id="popupCommentsList">
            <div class="text-center py-5"><i class="fas fa-spinner fa-spin text-primary"></i></div>
